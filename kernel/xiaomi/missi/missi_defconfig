# Linux/arm64 5.10 Kernel Configuration for Xiaomi Missi (Unisoc UMS9230)

# Architecture
CONFIG_ARM64=y
CONFIG_ARM64_VA_BITS=39
CONFIG_ARM64_PA_BITS=40
CONFIG_ARCH_UNISOC=y
CONFIG_HAVE_ARM_ARCH_TIMER=y

# Processor
CONFIG_SMP=y
CONFIG_NR_CPUS=8
CONFIG_HAVE_EFFICIENT_IPI=y
CONFIG_HOTPLUG_CPU=y

# Memory
CONFIG_PAGE_SIZE_4KB=y
CONFIG_ARCH_PHYS_ADDR_T_64BIT=y
CONFIG_HAVE_MMAP_EXEC_FAULT=y

# General Setup
CONFIG_HZ=100
CONFIG_HZ_100=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_GENERIC_CLOCKEVENTS_BROADCAST=y

# RCU
CONFIG_TREE_RCU=y
CONFIG_RCU_STALL_COMMON=y
CONFIG_RCU_FAST_NO_HZ=y

# DMA/IOMMU
CONFIG_IOMMU_SUPPORT=y
CONFIG_ARM_SMMU=y
CONFIG_IOMAP_FILEBASED=y

# PM/Suspend
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_PM_RUNTIME=y
CONFIG_PM_OPP=y
CONFIG_CPU_IDLE=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPUFREQ_DT=y

# Power Management
CONFIG_HAVE_CLK=y
CONFIG_GENERIC_CLOCKEVENTS=y

# USB
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_GADGET=y
CONFIG_USB_GADGET=y
CONFIG_USB_GADGET_VBUS_DRAW=500
CONFIG_USB_CONFIG_F_FS=y
CONFIG_USB_FUNCTION_FS=y
CONFIG_USB_FUNCTION_MTP=y
CONFIG_USB_FUNCTION_PTP=y

# Watchdog
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_CORE=y

# MTD/Nand
CONFIG_MTD=y
CONFIG_UFS_FS=y

# File Systems
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_SECURITY=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# Network File Systems
CONFIG_NFS_FS=y
CONFIG_NFS_V4=y

# Partition Types
CONFIG_PARTITION_ADVANCED=y
CONFIG_EFI_PARTITION=y
CONFIG_CMDLINE_PARTITION=y

# Device Drivers

# GPIO
CONFIG_GPIOLIB=y
CONFIG_GPIO_GENERIC_PLATFORM=y

# I2C
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_BOARDINFO=y

# SPI
CONFIG_SPI=y
CONFIG_SPI_MASTER=y

# UART
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_OF_PLATFORM=y

# DMA
CONFIG_DMA_ENGINE=y
CONFIG_DMA_OF=y

# Audio
CONFIG_SND=y
CONFIG_SND_SEQUENCER=y
CONFIG_SND_SOC=y
CONFIG_SND_SPRD=y

# Video/Camera
CONFIG_MEDIA_SUPPORT=y
CONFIG_VIDEO_V4L2=y
CONFIG_V4L_PLATFORM_DRIVERS=y
CONFIG_VIDEO_SPRD=y

# Display/DRM/GPU
CONFIG_DRM=y
CONFIG_DRM_SPRD=y
CONFIG_DRM_SPRD_PLANE=y
CONFIG_DRM_SPRD_LAYER=y
CONFIG_GPU_MALI=y
CONFIG_GPU_MALI_MIDGARD=y
CONFIG_GPU_MALI_MIDGARD_DEVICE_WITH_BASE=y

# Lights
CONFIG_LEDS=y
CONFIG_LEDS_GPIO=y

# Sensors/IIO
CONFIG_IIO=y
CONFIG_IIO_CONSUMERS_PER_TRIGGER=2
CONFIG_IIO_KFIFO_BUF=y
CONFIG_IIO_TRIGGER=y
CONFIG_IIO_SYSFS_TRIGGER=y

# Accelerometers
CONFIG_IIO_ST_ACCEL_3AXIS=y
CONFIG_IIO_ST_ACCEL_I2C_3AXIS=y

# Gyroscope
CONFIG_IIO_ST_GYRO_3AXIS=y
CONFIG_IIO_ST_GYRO_I2C_3AXIS=y

# Magnetometer
CONFIG_IIO_ST_MAGN_3AXIS=y
CONFIG_IIO_ST_MAGN_I2C_3AXIS=y

# Proximity/Light
CONFIG_IIO_PROXIMITY_SENSOR=y
CONFIG_IIO_LIGHT_SENSOR=y

# Input
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_INPUT_MISC=y

# RTC
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_SPRD=y

# Thermal
CONFIG_THERMAL=y
CONFIG_THERMAL_OF=y
CONFIG_THERMAL_DEFAULT_GOV_FAIR_SHARE=y

# Regulator
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y

# Crypto
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_SHA1=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_HASH=y

# Networking
CONFIG_NET=y
CONFIG_NETFILTER=y
CONFIG_NET_SCHED=y
CONFIG_NET_SCHED_QOS=y
CONFIG_CAN=y
CONFIG_CAN_VCAN=y

# WiFi
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_WLAN=y
CONFIG_QCA_CLD_WLAN=y

# Bluetooth
CONFIG_BT=y
CONFIG_BT_RFCOMM=y
CONFIG_BT_BNEP=y
CONFIG_BT_HIDP=y
CONFIG_BT_HCIUART=y

# NFC
CONFIG_NFC=y

# GPS/GNSS
CONFIG_GNSS=y

# Modem/RIL
CONFIG_SPRD_MODEM=y

# Pmic
CONFIG_PMIC_SPRD=y
CONFIG_REGULATOR_SPRD=y

# Security
CONFIG_HAVE_HARDENED_USERCOPY_ALLOCATOR=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_DEBUG_STACK_USAGE=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y

# SELinux
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y

# Debugging
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_BTF=y
CONFIG_DEBUG_KMEMLEAK=y
CONFIG_KPROBES=y
CONFIG_HAVE_KPROBES=y
CONFIG_HAVE_KRETPROBES=y
CONFIG_DEBUG_SPINLOCK=y

# Misc
CONFIG_PRINTK_TIME=y
CONFIG_PRINTK_CALLER=y
CONFIG_HARDCODED_GPIO=0
