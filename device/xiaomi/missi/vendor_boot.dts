	sprd-pcm-iis {
		compatible = "unisoc,sharkl5-pcm-platform";
		#sound-dai-cells = <0x00>;
		dmas = <0x27 0x05 0x27 0x06>;
		dma-names = "iis0_tx\0iis0_rx";
		sprd,dma-2stage-usecase = <0x02>;
		sprd,node-count-2stage-level-1 = <0x01>;
		sprd,syscon-pmu-apb = <0x12>;
		sprd,dma-2stage-level-1-int-source = <0x01>;
		phandle = <0xdf>;
	};

	sound@1 {
		compatible = "unisoc,i2s-null-codec";
		status = "disabled";
		sprd-audio-card,name = "all-i2s";
		phandle = <0x1c7>;

		sprd-audio-card,dai-link@0 {

			plat {
				sound-dai = <0xdf>;
			};

			cpu {
				sound-dai = <0xe0>;
			};

			codec {
				sound-dai = <0x00 0x00>;
			};
		};
	};

	sia81xx@L {
		compatible = "si,sia81xx";
		si,si_pa_type = "sia8100x";
		si,si_pa_reset = <0x29 0x3a 0x00>;
		si,si_pa_owi = <0x29 0x3a 0x00>;
		si,si_pa_id = <0x29 0x37 0x00>;
		si,si_pa_disable_pin = <0x00>;
		en_dynamic_id = <0x01>;
		channel_num = <0x00>;
		phandle = <0xd8>;
	};

	frsm_amp {
		compatible = "foursemi,frsm-amp";
		frsm,amp-ndev = <0x01>;
		frsm,class-enable;
		status = "okay";
		phandle = <0x1c8>;
	};

	memory@80000000 {
		device_type = "memory";
		reg = <0x00 0x80000000 0x02 0x00>;
	};

	chosen {
		stdout-path = "serial1:921600n8";
		bootargs = "earlycon console=ttyS1,921600n8\n       loop.max_part=7 loglevel=1 log_buf_len=2M kpti=0\n       firmware_class.path=/odm/firmware,/vendor/firmware\n       init=/init root=/dev/ram0 rw printk.devkmsg=on ftrace_dump_on_oops\n       swiotlb=1 dummy_hcd.num=0 rcupdate.rcu_expedited=1 rcu_nocbs=0-7";
		phandle = <0x1c9>;
	};

	sprd_backlight {
		compatible = "sprd,sharkl6-backlight";
		pwms = <0xe1 0x02 0x9c40>;
		pwm-names = "backlight";
		sprd,max-brightness-level = <0x39c>;
		default-brightness-level = <0x106>;
		sprd,brightness-scale = <0x3ff>;
