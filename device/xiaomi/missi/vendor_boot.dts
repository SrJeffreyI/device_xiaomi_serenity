/dts-v1/;

/ {
	cpuinfo_hardware = "Unisoc ums9230";
	soc-module = "UMS9230";
	soc-manufacturer = "Spreadtrum";
	interrupt-parent = <0x01>;
	#address-cells = <0x02>;
	#size-cells = <0x02>;
	model = "Spreadtrum UMS9230 1H10 SoC";
	compatible = "sprd,ums9230";
	sprd,sc-id = "ums9230 1000 1000";

	aliases {
		i2c0 = "/soc/ap-apb/i2c@0x200d0000";
		i2c1 = "/soc/ap-apb/i2c@0x200e0000";
		i2c2 = "/soc/ap-apb/i2c@0x200f0000";
		i2c3 = "/soc/ap-apb/i2c@0x20100000";
		i2c4 = "/soc/ap-apb/i2c@0x20110000";
		i2c5 = "/soc/ap-apb/i2c@0x20210000";
		i2c6 = "/soc/ap-apb/i2c@0x20220000";
		i2c7 = "/soc/aon/i2c@641A0000";
		spi0 = "/soc/ap-apb/spi@20120000";
		spi1 = "/soc/ap-apb/spi@20130000";
		spi2 = "/soc/ap-apb/spi@20140000";
		spi3 = "/soc/ap-apb/spi@20150000";
		spi4 = "/soc/aon/spi@64200000";
		v2-modem0 = "/modem@0";
		v2-modem1 = "/modem@1";
		seth0 = "/sipc-virt/core@5/channel@7";
		seth1 = "/sipc-virt/core@5/channel@8";
		seth2 = "/sipc-virt/core@5/channel@9";
		seth3 = "/sipc-virt/core@5/channel@18";
		seth4 = "/sipc-virt/core@5/channel@19";
		seth5 = "/sipc-virt/core@5/channel@20";
		seth6 = "/sipc-virt/core@5/channel@24";
		seth7 = "/sipc-virt/core@5/channel@25";
		seth8 = "/sipc-virt/core@5/channel@26";
		seth9 = "/sipc-virt/core@5/channel@27";
		seth10 = "/sipc-virt/core@5/channel@28";
		seth11 = "/sipc-virt/core@5/channel@29";
		seth12 = "/sipc-virt/core@5/channel@30";
		seth13 = "/sipc-virt/core@5/channel@31";
		cooling-device0 = "/cooling-devices/cluster0-cooling";
		cooling-device1 = "/cooling-devices/cluster1-cooling";
		thm-sensor0 = "/virtual-sensor@0";
		serial0 = "/soc/ap-apb/serial@0x200a0000";
		serial1 = "/soc/ap-apb/serial@0x200b0000";
		serial2 = "/soc/ap-apb/serial@0x200c0000";
		mmc0 = "/soc/ap-apb/sdio@201d0000";
		mmc1 = "/soc/ap-apb/sdio@201a0000";
		mmc2 = "/soc/ap-apb/sdio@201b0000";
		pmic_pwroff = "/soc/aon/spi@64200000/pmic@0/poweroff@1820";
	};

	cpus {
		#address-cells = <0x02>;
		#size-cells = <0x00>;

		cpu-map {

			cluster0 {

				core0 {
					cpu = <0x02>;
				};

				core1 {
					cpu = <0x03>;
				};

				core2 {
					cpu = <0x04>;
				};

				core3 {
					cpu = <0x05>;
				};

				core4 {
					cpu = <0x06>;
				};

				core5 {
					cpu = <0x07>;
				};

				core6 {
					cpu = <0x08>;
				};

				core7 {
					cpu = <0x09>;
				};
			};
		};

		cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x00 0x00>;
			enable-method = "psci";
			cpu-idle-states = <0x0a 0x0b>;
			capacity-dmips-mhz = <0x220>;
			dynamic-power-coefficient = <0x66>;
			#cooling-cells = <0x02>;
			sugov_slack_timer;
			sprd,freq-domain = <0x0c 0x00>;
			phandle = <0x02>;
		};

		cpu@100 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x00 0x100>;
			enable-method = "psci";
			cpu-idle-states = <0x0a 0x0b>;
			capacity-dmips-mhz = <0x220>;
			dynamic-power-coefficient = <0x66>;
			#cooling-cells = <0x02>;
			sprd,freq-domain = <0x0c 0x00>;
			phandle = <0x03>;
		};

		cpu@200 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x00 0x200>;
			enable-method = "psci";
			cpu-idle-states = <0x0a 0x0b>;
			capacity-dmips-mhz = <0x220>;
			dynamic-power-coefficient = <0x66>;
			#cooling-cells = <0x02>;
			sprd,freq-domain = <0x0c 0x00>;
			phandle = <0x04>;
		};

		cpu@300 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x00 0x300>;
			enable-method = "psci";
			cpu-idle-states = <0x0a 0x0b>;
			capacity-dmips-mhz = <0x220>;
			dynamic-power-coefficient = <0x66>;
			#cooling-cells = <0x02>;
			sprd,freq-domain = <0x0c 0x00>;
			phandle = <0x05>;
		};

		cpu@400 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x00 0x400>;
			enable-method = "psci";
			cpu-idle-states = <0x0a 0x0b>;
			capacity-dmips-mhz = <0x220>;
			dynamic-power-coefficient = <0x66>;
			#cooling-cells = <0x02>;
			sprd,freq-domain = <0x0c 0x00>;
			phandle = <0x06>;
		};

		cpu@500 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x00 0x500>;
			enable-method = "psci";
			cpu-idle-states = <0x0a 0x0b>;
			capacity-dmips-mhz = <0x220>;
			dynamic-power-coefficient = <0x66>;
			#cooling-cells = <0x02>;
			sprd,freq-domain = <0x0c 0x00>;
			phandle = <0x07>;
		};

		cpu@600 {
			device_type = "cpu";
			compatible = "arm,cortex-a75";
			reg = <0x00 0x600>;
			enable-method = "psci";
			cpu-idle-states = <0x0d 0x0b>;
			capacity-dmips-mhz = <0x400>;
			dynamic-power-coefficient = <0x1f5>;
			#cooling-cells = <0x02>;
			sprd,freq-domain = <0x0e 0x01>;
			phandle = <0x08>;
		};

		cpu@700 {
			device_type = "cpu";
			compatible = "arm,cortex-a75";
			reg = <0x00 0x700>;
			enable-method = "psci";
			cpu-idle-states = <0x0d 0x0b>;
			capacity-dmips-mhz = <0x400>;
			dynamic-power-coefficient = <0x1f5>;
			#cooling-cells = <0x02>;
			sprd,freq-domain = <0x0e 0x01>;
			phandle = <0x09>;
		};
	};

	idle-states {
		entry-method = "arm,psci";

		lit_core-pd {
			compatible = "arm,idle-state";
			entry-latency-us = <0x3e8>;
			exit-latency-us = <0x1f4>;
			min-residency-us = <0x9c4>;
			local-timer-stop;
			arm,psci-suspend-param = <0x10000>;
			phandle = <0x0a>;
		};

		big_core-pd {
			compatible = "arm,idle-state";
			entry-latency-us = <0xfa0>;
			exit-latency-us = <0xfa0>;
			min-residency-us = <0x2710>;
			local-timer-stop;
			arm,psci-suspend-param = <0x10000>;
			phandle = <0x0d>;
		};

		apsys_pd {
			compatible = "arm,idle-state";
			entry-latency-us = <0x2710>;
			exit-latency-us = <0x2710>;
			min-residency-us = <0x2710>;
			local-timer-stop;
			arm,psci-suspend-param = <0x2010000>;
			phandle = <0x0b>;
		};
	};

	psci {
		compatible = "arm,psci-0.2";
		method = "smc";
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = <0x01 0x0d 0x04 0x01 0x0e 0x04 0x01 0x0b 0x04 0x01 0x0a 0x04>;
		arm,no-tick-in-suspend;
	};

	pmu {
		compatible = "arm,armv8-pmuv3";
		interrupts = <0x00 0x70 0x04 0x00 0x71 0x04 0x00 0x72 0x04 0x00 0x73 0x04 0x00 0x74 0x04 0x00 0x75 0x04 0x00 0x76 0x04 0x00 0x77 0x04>;
	};

	sprd-gsp {
		compatible = "sprd,gsp-r8p0-qogirl6";
		core-cnt = <0x01>;
		io-cnt = <0x07>;
		cores = <0x0f>;
		phandle = <0xe4>;
	};

	soc {
		compatible = "simple-bus";
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;
		phandle = <0xe7>;

		interrupt-controller@10000000 {
			compatible = "arm,gic-v3";
			#interrupt-cells = <0x03>;
			#address-cells = <0x02>;
			#size-cells = <0x02>;
			ranges;
			redistributor-stride = <0x00 0x20000>;
			#redistributor-regions = <0x01>;
			interrupt-controller;
			reg = <0x00 0x10000000 0x00 0x20000 0x00 0x10040000 0x00 0x100000>;
			interrupts = <0x01 0x09 0x04>;
			phandle = <0x01>;
		};

		agcp {
			compatible = "simple-bus";
			#address-cells = <0x02>;
			#size-cells = <0x02>;
			ranges;
			phandle = <0xe8>;

			dma-controller@56580000 {
				compatible = "sprd,qogirl6-dma\0sprd,sc9860-dma";
				reg = <0x00 0x56580000 0x00 0x4000>;
				interrupts = <0x00 0xb4 0x04>;
				#dma-cells = <0x01>;
				#dma-channels = <0x20>;
				clock-names = "enable\0ashb_eb";
				clocks = <0x10 0x06 0x10 0x0d>;
				phandle = <0xbd>;
			};

			agdsp-power-domain {
				compatible = "sprd,agdsp-pd";
				sprd,syscon-agcp-ahb = <0x11>;
				sprd,syscon-pmu-apb = <0x12>;
				audcp_pmu_sleep_ctrl = <0x12 0x850 0x08>;
				audcp_pmu_slp_status = <0x12 0x860 0xf000>;
				audcp_pmu_pwr_status4 = <0x12 0x544 0x1f00>;
				audcp_pmu_pwr_status3 = <0x12 0x544 0x1f0000>;
				ap_access_ena = <0x11 0x14c 0x20>;
				sprd,ddr-addr-offset = <0x00>;
				sprd,auto_agcp_access = <0x00>;
				sprd,syscon-agcp-glb = <0x13>;
				sprd,syscon-agcp-apb = <0x14>;
				#power-domain-cells = <0x00>;
				status = "disabled";
				phandle = <0x23>;
			};

			vbc@56480000 {
				compatible = "unisoc,qogirl6-vbc";
				#sound-dai-cells = <0x01>;
				reg = <0x00 0x56480000 0x00 0x1000>;
				sprd,syscon-agcp-ahb = <0x13>;
				sprd,vbc-phy-offset = <0x00>;
				pinctrl-names = "vbc_iis3_0\0vbc_iism0_0\0vbc_iis_to_pad\0vbc_iis_to_aon_usb\0vbc_iism0_1\0vbc_iism0_3\0vbc_iis0_3\0vbc_iis1_3\0vbc_iis2_3\0vbc_iis3_3\0ap_iis0_3\0vbc_iis3_5\0audcp_iis0_1";
				pinctrl-0 = <0x15>;
				pinctrl-1 = <0x16>;
				pinctrl-2 = <0x17>;
				pinctrl-3 = <0x18>;
				pinctrl-4 = <0x19>;
				pinctrl-5 = <0x1a>;
				pinctrl-6 = <0x1b>;
				pinctrl-7 = <0x1c>;
				pinctrl-8 = <0x1d>;
				pinctrl-9 = <0x1e>;
				pinctrl-10 = <0x1f>;
				pinctrl-11 = <0x20>;
				pinctrl-12 = <0x21>;
				pinctrl-13 = <0x22>;
				power-domains = <0x23>;
				phandle = <0xdd>;
			};

			pdm-dmic@56401000 {
				compatible = "unisoc,pdm";
				status = "disabled";
				reg = <0x00 0x56401000 0x00 0x1000>;
				#sound-dai-cells = <0x01>;
				sprd,syscon-agcp-ahb = <0x13>;
				power-domains = <0x23>;
				phandle = <0xe9>;
			};

			mcdt@56490000 {
				compatible = "unisoc,mcdt-r2p0";
				reg = <0x00 0x56490000 0x00 0x170>;
				interrupts = <0x00 0xb6 0x04>;
				sprd,ap-addr-offset = <0x00>;
				sprd,syscon-agcp-ahb = <0x13>;
			};

			audio-codec@56750000 {
				compatible = "unisoc,audio-codec-dig-agcp";
				reg = <0x00 0x56750000 0x00 0x1000>;
				sprd,syscon-agcp-ahb = <0x13>;
				power-domains = <0x23>;
				phandle = <0x71>;
			};
		};

		ap-apb {
			compatible = "simple-bus";
			#address-cells = <0x02>;
			#size-cells = <0x02>;
			ranges;
			phandle = <0xea>;

			serial@0x200a0000 {
				compatible = "sprd,ums9230-uart\0sprd,sc9836-uart";
				reg = <0x00 0x200a0000 0x00 0x100>;
				interrupts = <0x00 0x02 0x04>;
				source-base = <0x20010024>;
				clock-names = "enable\0uart\0source";
				clocks = <0x24 0x0e 0x25 0x01 0x26>;
				status = "okay";
				phandle = <0xeb>;
			};

			serial@0x200b0000 {
				compatible = "sprd,ums9230-uart\0sprd,sc9836-uart";
				reg = <0x00 0x200b0000 0x00 0x100>;
				interrupts = <0x00 0x03 0x04>;
				source-base = <0x20010028>;
				clock-names = "enable\0uart\0source";
				clocks = <0x24 0x0f 0x25 0x02 0x26>;
				status = "okay";
				phandle = <0xec>;
			};

			serial@0x200c0000 {
				compatible = "sprd,ums9230-uart\0sprd,sc9836-uart";
				reg = <0x00 0x200c0000 0x00 0x100>;
				interrupts = <0x00 0x04 0x04>;
				source-base = <0x2001002c>;
				clock-names = "enable\0uart\0source";
				clocks = <0x24 0x10 0x25 0x03 0x26>;
				status = "okay";
				phandle = <0xed>;
			};

			i2c@0x200d0000 {
				compatible = "sprd,qogirl6-i2c\0sprd,sc9860-i2c";
				reg = <0x00 0x200d0000 0x00 0x100>;
				interrupts = <0x00 0x0b 0x04>;
				clock-frequency = <0x61a80>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				dma-names = "rx\0tx";
				dmas = <0x27 0x17 0x27 0x18>;
				status = "disabled";
				reset-names = "i2c_rst";
				resets = <0x24 0x08>;
				clock-names = "enable\0i2c\0source";
				clocks = <0x24 0x09 0x25 0x04 0x26>;
				phandle = <0xee>;
			};

			i2c@0x200e0000 {
				compatible = "sprd,qogirl6-i2c\0sprd,sc9860-i2c";
				reg = <0x00 0x200e0000 0x00 0x100>;
				interrupts = <0x00 0x0c 0x04>;
				clock-frequency = <0x61a80>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				dma-names = "rx\0tx";
				dmas = <0x27 0x19 0x27 0x1a>;
				status = "disabled";
				reset-names = "i2c_rst";
				resets = <0x24 0x09>;
				clock-names = "enable\0i2c\0source";
				clocks = <0x24 0x0a 0x25 0x05 0x26>;
				phandle = <0xef>;
			};

			i2c@0x200f0000 {
				compatible = "sprd,qogirl6-i2c\0sprd,sc9860-i2c";
				reg = <0x00 0x200f0000 0x00 0x100>;
				interrupts = <0x00 0x0d 0x04>;
				clock-frequency = <0x61a80>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				dma-names = "rx\0tx";
				dmas = <0x27 0x1b 0x27 0x1c>;
				status = "disabled";
				reset-names = "i2c_rst";
				resets = <0x24 0x0a>;
				clock-names = "enable\0i2c\0source";
				clocks = <0x24 0x0b 0x25 0x06 0x26>;
				phandle = <0xf0>;
			};

			i2c@0x20100000 {
				compatible = "sprd,qogirl6-i2c\0sprd,sc9860-i2c";
				reg = <0x00 0x20100000 0x00 0x100>;
				interrupts = <0x00 0x0e 0x04>;
				clock-frequency = <0x61a80>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				dma-names = "rx\0tx";
				dmas = <0x27 0x1d 0x27 0x1e>;
				status = "disabled";
				reset-names = "i2c_rst";
				resets = <0x24 0x0b>;
				clock-names = "enable\0i2c\0source";
				clocks = <0x24 0x0c 0x25 0x07 0x26>;
				phandle = <0xf1>;
			};

			i2c@0x20110000 {
				compatible = "sprd,qogirl6-i2c\0sprd,sc9860-i2c";
				reg = <0x00 0x20110000 0x00 0x100>;
				interrupts = <0x00 0x0f 0x04>;
				clock-frequency = <0x61a80>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				dma-names = "rx\0tx";
				dmas = <0x27 0x1f 0x27 0x20>;
				status = "disabled";
				reset-names = "i2c_rst";
				resets = <0x24 0x0c>;
				clock-names = "enable\0i2c\0source";
				clocks = <0x24 0x0d 0x25 0x08 0x26>;
				phandle = <0xf2>;
			};

			i2s@0x20160000 {
				compatible = "sprd,i2s";
				reg = <0x00 0x20160000 0x00 0x1000>;
				sprd,dai_name = "i2s_bt_sco0";
				sprd,hw_port = <0x00>;
				sprd,syscon-ap-apb = <0x28>;
				#sound-dai-cells = <0x00>;
				status = "okay";
				clock-names = "clk_iis0";
				clocks = <0x25 0x0f>;
				sprd,config_type = "pcm";
				sprd,slave_timeout = <0xf11>;
				sprd,fs = <0x1f40>;
				sprd,bus_type = <0x01>;
				sprd,rtx_mode = <0x03>;
				sprd,byte_per_chan = <0x01>;
				sprd,slave_mode = <0x00>;
				sprd,lsb = <0x00>;
				sprd,lrck = <0x00>;
				sprd,low_for_left = <0x01>;
				sprd,clk_inv = <0x00>;
				sprd,pcm_short_frame = <0x01>;
				sprd,pcm_slot = <0x01>;
				sprd,pcm_cycle = <0x01>;
				sprd,tx_watermark = <0x0c>;
				sprd,rx_watermark = <0x14>;
				phandle = <0xe0>;
			};

			i2c@0x20210000 {
				compatible = "sprd,qogirl6-i2c\0sprd,sc9860-i2c";
				reg = <0x00 0x20210000 0x00 0x100>;
				interrupts = <0x00 0x23 0x04>;
				clock-frequency = <0x61a80>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				dma-names = "rx\0tx";
				dmas = <0x27 0x21 0x27 0x22>;
				status = "disabled";
				reset-names = "i2c_rst";
				resets = <0x24 0x1a>;
				clock-names = "enable\0i2c\0source";
				clocks = <0x24 0x1a 0x25 0x09 0x26>;
				phandle = <0xf3>;
			};

			i2c@0x20220000 {
				compatible = "sprd,qogirl6-i2c\0sprd,sc9860-i2c";
				reg = <0x00 0x20220000 0x00 0x100>;
				interrupts = <0x00 0x24 0x04>;
				clock-frequency = <0x61a80>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				dma-names = "rx\0tx";
				dmas = <0x27 0x23 0x27 0x24>;
				status = "okay";
				reset-names = "i2c_rst";
				resets = <0x24 0x1b>;
				clock-names = "enable\0i2c\0source";
				clocks = <0x24 0x1b 0x25 0x0a 0x26>;
				phandle = <0xf4>;

				fs15xx@34 {
					compatible = "foursemi,fs1588";
					reg = <0x34>;
					spkr-id = <0x01>;
					fwm-name = "frsm-spk1.bin";
					mod-gpios = <0x29 0x3a 0x00>;
					fs15wt-series;
					status = "okay";
					phandle = <0xf5>;
				};
			};

			spi@20120000 {
				compatible = "sprd,sc9860-spi\0sprd,sharkl5-spi";
				reg = <0x00 0x20120000 0x00 0x1000>;
				interrupts = <0x00 0x05 0x04>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				status = "okay";
