	dmabuf {
		compatible = "sprd,dmabuf";
		phandle = <0x1ca>;
	};

	display-subsystem {
		compatible = "sprd,display-subsystem";
		ports = <0xe2>;
		spi_ports = <0xe3>;
		gsp = <0xe4>;
	};

	audcp-iram@65009400 {
		reg = <0x00 0x65009400 0x00 0x1000>;
		phandle = <0xbe>;
	};

	dpu-dvfs {
		compatible = "sprd,hwdvfs-dpu-qogirl6";
		sprd,hw-dfs-en = <0x00>;
		sprd,work-index-def = <0x04>;
		sprd,idle-index-def = <0x01>;
		sprd,freq-upd-delay-en = <0x00>;
		sprd,freq-upd-hdsk-en = <0x01>;
		operating-points = <0x25800 0xaae60 0x2ee00 0xaae60 0x3e800 0xaae60 0x4b000 0xaae60 0x5dc00 0xb71b0>;
		phandle = <0x1cb>;
	};

	vsp-dvfs {
		compatible = "sprd,hwdvfs-vsp-qogirl6";
		sprd,dvfs-work-freq = <0x16e36000>;
		sprd,dvfs-idle-freq = <0xf424000>;
		sprd,dvfs-enable-flag = <0x01>;
		sprd,freq-upd-delay-en = <0x00>;
		sprd,freq-upd-hdsk-en = <0x01>;
		operating-points = <0x3e800 0xaae60 0x4b000 0xaae60 0x5dc00 0xb71b0>;
		phandle = <0x1cc>;
	};

	firmware {

		android {
			compatible = "android,firmware";

			vbmeta {
				compatible = "android,vbmeta";
				parts = "vbmeta,boot,init_boot,vendor_boot,dtbo,l_modem,pm_sys,l_ldsp,l_gdsp,l_agdsp";
			};
		};
	};

	rebootescrow@0 {
		compatible = "pmem-region";
		reg = <0x00 0xfff70000 0x00 0x10000>;
	};

	extcon-gpio {
		compatible = "linux,extcon-usb-gpio";
		vbus-gpio = <0x67 0x00 0x00>;
		phandle = <0xe5>;
	};

	virtual_typec {
		compatible = "sprd,virtual-typec";
		extcon = <0xe5>;
		status = "okay";
		phandle = <0x1cd>;
	};

	sensorhub {
		compatible = "sprd,qogirl6-sensorhub\0sprd,sensor-hub";
	};

	sprd-map-user {
		compatible = "unisoc,map-user";
	};

	autotest {
		compatible = "sprd,autotest";
		sprd,pinctrl = <0xe6>;
		phandle = <0x1ce>;
	};

